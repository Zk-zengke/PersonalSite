{
  "name": "personal-learning-site",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @learning/api --filter @learning/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @learning/api prisma:generate",
    "db:migrate": "pnpm --filter @learning/api prisma:migrate",
    "db:seed": "pnpm --filter @learning/api prisma:seed"
  }
}
