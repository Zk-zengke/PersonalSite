# SMTP connection. Use an app password / authorization code, not your mailbox password.
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURITY=ssl
SMTP_USERNAME=your-address@qq.com
SMTP_PASSWORD=your-smtp-authorization-code
MAIL_FROM=your-address@qq.com
MAIL_TO=your-address@qq.com

SITE_URL=https://www.crossking.me
API_URL=https://www.crossking.me/api/health
SITE_MAX_SECONDS=3.0
API_MAX_SECONDS=2.0
DISK_MAX_PERCENT=85
ALERT_REPEAT_MINUTES=60
