generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  coverImage  String?
  sortOrder   Int       @default(0)
  articles    Article[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([sortOrder])
}

model Article {
  id         String   @id @default(uuid())
  title      String
  slug       String   @unique
  summary    String?
  content    String   @db.Text
  coverImage String?
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  tags       String[] @default([])
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([categoryId, published, createdAt])
}

model Photo {
  id          String   @id @default(uuid())
  title       String
  description String?
  imageUrl    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
}

model Moment {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  tags      String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}
